# Build artifacts (root-only — `fakeaws` is also a directory under cmd/,
# so we anchor the pattern to repo root with a leading slash.)
/fakeaws
/cov.out
/coverage.html

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Local dev
*.db
*.db-journal
*.db-wal
*.db-shm

# Secrets — also caught by gitleaks pre-commit hook
.env
.env.*
*.pem
*.key
credentials.json

# Terraform state from running examples locally (mirror of mockway's
# .gitignore patterns). The .terraform/ provider-cache dir can be
# hundreds of MB; tfstate files contain a snapshot of mock state and
# should never be committed.
examples/**/.terraform/
examples/**/.terraform.lock.hcl
examples/**/terraform.tfstate
examples/**/terraform.tfstate.backup
examples/**/terraform.tfstate.*.backup
